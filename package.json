{
    "name": "ytm-tunnel-desktop",
    "version": "0.1.1",
    "description": "Dedicated YouTube Music desktop client with app-local SOCKS5 proxy",
    "main": "main.js",
    "author": "Jeongwan Jeon <jjw@jjw.kr>",
    "license": "MIT",
    "private": true,
    "scripts": {
        "start": "electron .",
        "dev": "cross-env NODE_ENV=development electron .",
        "start:noproxy": "cross-env YTM_USE_PROXY=false electron .",
        "convert:wg": "node ./scripts/convert-wg-to-singbox.js",
        "vendor:singbox": "node ./scripts/download-singbox.js",
        "test:tunnel": "node ./scripts/test-tunnel.js",
        "build": "npm run vendor:singbox && electron-builder",
        "build:win": "npm run vendor:singbox && electron-builder --win nsis"
    },
    "build": {
        "appId": "com.example.ytmtunneldesktop",
        "productName": "YTM Tunnel Desktop",
        "asar": true,
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "singbox.js",
            "wg-convert.js",
            "preload.js",
            "preload-eq.js",
            "eq.html",
            "assets",
            "package.json"
        ],
        "extraResources": [
            {
                "from": "vendor/sing-box",
                "to": "sing-box",
                "filter": [
                    "sing-box.exe",
                    "sing-box"
                ]
            }
        ],
        "win": {
            "icon": "assets/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "mac": {
            "icon": "assets/icon.icns",
            "artifactName": "${productName}-${version}-${arch}.${ext}",
            "target": [
                "dmg",
                "zip"
            ]
        },
        "linux": {
            "icon": "assets/icon.png",
            "target": [
                "AppImage",
                "deb"
            ]
        },
        "nsis": {
            "oneClick": false,
            "perMachine": false,
            "allowToChangeInstallationDirectory": true
        }
    },
    "devDependencies": {
        "cross-env": "^7.0.3",
        "electron": "^42.1.0",
        "electron-builder": "^26.0.12"
    }
}
